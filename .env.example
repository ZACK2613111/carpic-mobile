# Copy this file to ".env" and fill in your Supabase project values.
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the app bundle.
# The publishable key is safe to ship in a client app (Row Level Security protects your data).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
